# AI Gateway 配置模板
# 复制此文件为 .env 并填入真实值

# ===== 必填：加密密钥 =====
# 至少 32 字符随机字符串
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
# 32 字节 AES 密钥
ENCRYPTION_KEY=change-this-to-32-byte-key!!

# ===== 数据库配置 =====
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_gateway
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=postgres

# ===== 钉钉配置（可选，留空则使用开发模式） =====
DINGTALK_APP_ID=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ===== 其他配置 =====
FRONTEND_URL=http://localhost:3000
DEBUG=false
DEFAULT_QUOTA_AMOUNT=50.0
RATE_LIMIT_USER_QPS=10
RATE_LIMIT_PROVIDER_QPS=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
